# Copy this file to .env and fill in your values

PORT=4000

# Get your key from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# Model used to generate the personalized readings.
# Current models as of mid-2026: claude-sonnet-5, claude-opus-4-8, claude-haiku-4-5-20251001
ANTHROPIC_MODEL=claude-sonnet-5

# Nominatim (OpenStreetMap) requires a descriptive User-Agent per their usage policy.
# Use your app name plus a real contact email or project URL — example.com addresses are blocked.
NOMINATIM_USER_AGENT=VedicAstrologyApp/1.0 (local-development)
